---
title: 闲言碎语
type: talk
layout: talk
---

{% note primary %}
**本页面代码 powered by 我自己**
{% endnote %}

<style>

.talk-page {
  max-width: 700px;
  margin: 0 auto;
  padding: 0 16px 72px;
  font-family: 'Noto Serif SC', serif;
}

/* ── 顶部统计 ── */
.talk-stat {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 20px 0 36px;
  color: var(--text-color);
  opacity: .5;
  font-size: .8em;
  letter-spacing: .08em;
}
.talk-stat::before,
.talk-stat::after {
  content: '';
  flex: 1;
  height: 1px;
  background: currentColor;
  opacity: .25;
}

/* ── 时间线 ── */
.talk-timeline {
  position: relative;
  padding-left: 30px;
}
.talk-timeline::before {
  content: '';
  position: absolute;
  left: 7px; top: 12px; bottom: 12px;
  width: 1px;
  /* 用主题色做渐变轴线 */
  background: linear-gradient(
    180deg,
    var(--highlight-color, #1abc9c) 0%,
    transparent 100%
  );
  opacity: .35;
}

.talk-item {
  position: relative;
  margin-bottom: 22px;
  animation: tkIn .4s cubic-bezier(.22,1,.36,1) both;
}

/* 时间轴圆点 */
.talk-item::before {
  content: '';
  position: absolute;
  left: -24px; top: 13px;
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--highlight-color, #1abc9c);
  opacity: .55;
  box-shadow: 0 0 0 2px var(--board-bg-color, #fff);
  transition: opacity .2s, transform .2s;
}
.talk-item:hover::before {
  opacity: 1;
  transform: scale(1.5);
}

/* ── 卡片 ── */
.talk-card {
  background: var(--board-bg-color, #fff);
  border-radius: 12px;
  padding: 15px 18px 12px;
  /* 深浅模式通用阴影：亮色用暖灰，深色会因背景深而自然淡化 */
  box-shadow: 0 1px 4px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.05);
  border: 1px solid rgba(128,128,128,.1);
  transition: transform .2s, box-shadow .2s;
}
.talk-card:hover {
  transform: translateX(5px);
  box-shadow: 0 2px 8px rgba(0,0,0,.08), 0 8px 24px rgba(0,0,0,.07);
}

.talk-time {
  font-size: .72em;
  color: var(--text-color);
  opacity: .4;
  margin-bottom: 8px;
  font-family: monospace;
  letter-spacing: .02em;
}

.talk-content {
  font-size: .93em;
  line-height: 1.9;
  color: var(--text-color);
  word-break: break-word;
}

/* ── 图片 ── */
.talk-content img {
  display: block;
  max-width: 100%;
  max-height: 340px;
  object-fit: cover;
  border-radius: 9px;
  margin-top: 10px;
  cursor: zoom-in;
  transition: filter .2s, transform .2s;
}
.talk-content img:hover {
  filter: brightness(.93);
  transform: scale(1.01);
}
/* 多图网格 */
.talk-imgs {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  gap: 6px;
  margin-top: 10px;
}
.talk-imgs img {
  width: 100%;
  aspect-ratio: 1;
  object-fit: cover;
  border-radius: 7px;
  cursor: zoom-in;
  max-height: none;
  margin-top: 0;
  transition: filter .2s, transform .2s;
}
.talk-imgs img:hover { filter: brightness(.9); transform: scale(1.04); }

/* ── 底部操作栏（点赞） ── */
.talk-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-top: 10px;
  padding-top: 9px;
  border-top: 1px solid rgba(128,128,128,.1);
}

.like-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: none;
  border: 1px solid rgba(128,128,128,.18);
  border-radius: 20px;
  padding: 3px 11px 3px 9px;
  font-size: .78em;
  font-family: 'Noto Serif SC', serif;
  color: var(--text-color);
  opacity: .55;
  cursor: pointer;
  transition: all .2s;
  line-height: 1.6;
  user-select: none;
}
.like-btn:hover {
  opacity: .9;
  border-color: #e74c6e;
  color: #e74c6e;
}
.like-btn.liked {
  border-color: #e74c6e;
  color: #e74c6e;
  opacity: 1;
  background: rgba(231,76,110,.07);
}
/* 点赞动画 */
.like-btn.pop .like-heart {
  animation: tkHeart .35s cubic-bezier(.36,.07,.19,.97);
}
.like-heart {
  display: inline-block;
  font-style: normal;
  line-height: 1;
  transform-origin: center;
}

/* ── 灯箱 ── */
.tk-lightbox {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.82);
  z-index: 9999;
  align-items: center;
  justify-content: center;
  cursor: zoom-out;
  backdrop-filter: blur(8px);
}
.tk-lightbox.open {
  display: flex;
  animation: tkLbFade .2s ease;
}
.tk-lightbox img {
  max-width: 90vw;
  max-height: 86vh;
  object-fit: contain;
  border-radius: 10px;
  box-shadow: 0 12px 60px rgba(0,0,0,.65);
  cursor: default;
  animation: tkLbScale .22s ease;
}
.tk-lb-x {
  position: absolute;
  top: 16px; right: 20px;
  color: rgba(255,255,255,.65);
  font-size: 1.8em;
  line-height: 1;
  cursor: pointer;
  transition: color .15s;
}
.tk-lb-x:hover { color: #fff; }

/* ── 加载更多 ── */
.talk-more {
  text-align: center;
  padding: 6px 0 4px;
}
.talk-more button {
  background: none;
  border: 1px solid rgba(128,128,128,.2);
  border-radius: 20px;
  padding: 7px 26px;
  font-size: .82em;
  font-family: 'Noto Serif SC', serif;
  color: var(--text-color);
  opacity: .55;
  cursor: pointer;
  letter-spacing: .04em;
  transition: all .2s;
}
.talk-more button:hover {
  opacity: 1;
  border-color: var(--highlight-color, #1abc9c);
  color: var(--highlight-color, #1abc9c);
}
.talk-more button:disabled { opacity: .25; cursor: default; }

/* ── 状态 ── */
.talk-empty {
  text-align: center;
  color: var(--text-color);
  opacity: .35;
  padding: 60px 0;
  font-size: .9em;
}
.talk-spinner {
  text-align: center;
  padding: 48px 0;
}
.talk-spinner span {
  display: inline-block;
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--highlight-color, #1abc9c);
  margin: 0 3px;
  opacity: .6;
  animation: tkDot .9s infinite ease-in-out;
}
.talk-spinner span:nth-child(2) { animation-delay: .18s; }
.talk-spinner span:nth-child(3) { animation-delay: .36s; }

/* ── keyframes ── */
@keyframes tkIn {
  from { opacity:0; transform:translateY(10px); }
  to   { opacity:1; transform:translateY(0); }
}
@keyframes tkDot {
  0%,80%,100% { transform:scale(.5); opacity:.3; }
  40%          { transform:scale(1.1); opacity:.8; }
}
@keyframes tkLbFade { from{opacity:0} to{opacity:1} }
@keyframes tkLbScale {
  from { transform:scale(.9); opacity:0; }
  to   { transform:scale(1);  opacity:1; }
}
@keyframes tkHeart {
  0%   { transform:scale(1); }
  30%  { transform:scale(1.6); }
  60%  { transform:scale(.85); }
  100% { transform:scale(1); }
}
</style>

<div class="talk-page">
  <div class="talk-count" id="talk-count">正在加载...</div>
  <div id="talk-list">
    <div class="talk-spinner"><span></span><span></span><span></span></div>
  </div>
  <div class="talk-loadmore" id="talk-loadmore" style="display:none">
    <button id="loadmore-btn" onclick="tkLoadMore()">加载更多</button>
  </div>
</div>

