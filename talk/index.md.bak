  <div class="tk-lb-close" onclick="tkCloseLb()">✕</div>
  <img id="tk-lb-img" src="" alt="">
</div> -->

<script src="https://registry.npmmirror.com/twikoo/1.6.45/files/dist/twikoo.all.min.js"></script>
<script>
/* ===== 配置 ===== */
const TK_ENV    = 'https://comment.linzekai.cn/'; // ← 改这里
const TK_PATH   = '/talk/';  // 说说路径，与 Twikoo 发布时一致
const TK_STEP   = 20;        // 每次「加载更多」渲染条数
/* ================ */

let tkAll      = [];  // 全部拉取到的说说
let tkShown    = 0;   // 已渲染条数

/* ── 1. 拉取数据（API 单次上限 100，循环请求直到拿完） ──
   注意：getRecentComments 不支持 offset 参数，
   实际只能拿最新 100 条。若官方未来支持 offset 可在此扩展。 */
async function tkFetch() {
  const data = await twikoo.getRecentComments({
    envId: TK_ENV,
    urls: [TK_PATH],
    pageSize: 100,
    includeReply: false
  });
  return data;
}

/* ── 2. 初始化 ── */
async function tkInit() {
  try {
    tkAll = await tkFetch();
  } catch (e) {
    document.getElementById('talk-list').innerHTML =
      '<div class="talk-empty">加载失败，请检查 Twikoo 配置 😢</div>';
    document.getElementById('talk-count').textContent = '';
    console.error(e);
    return;
  }

  const countEl = document.getElementById('talk-count');

  if (!tkAll.length) {
    countEl.textContent = '';
    document.getElementById('talk-list').innerHTML =
      '<div class="talk-empty">还没有说说，快去发一条吧～</div>';
    return;
  }

  countEl.textContent = `共 ${tkAll.length} 条碎碎念`;
  document.getElementById('talk-list').innerHTML =
    '<div class="talk-timeline" id="tk-timeline"></div>';

  tkRenderNext(); // 首屏

  if (tkAll.length > TK_STEP) {
    const btn = document.getElementById('loadmore-btn');
    btn.textContent = `加载更多（还有 ${tkAll.length - TK_STEP} 条）`;
    document.getElementById('talk-loadmore').style.display = 'block';
  }
}

/* ── 3. 渲染下一批 ── */
function tkRenderNext() {
  const timeline = document.getElementById('tk-timeline');
  const slice = tkAll.slice(tkShown, tkShown + TK_STEP);

  slice.forEach((c, i) => {
    const div = document.createElement('div');
    div.className = 'talk-item';
    div.style.animationDelay = `${Math.min(i, 8) * 0.045}s`;
    div.innerHTML = `
      <div class="talk-card">
        <div class="talk-time">${tkFmtTime(c.created)}</div>
        <div class="talk-content">${tkProcessHtml(c.comment)}</div>
      </div>`;
    timeline.appendChild(div);
  });

  tkShown += slice.length;
  tkBindImgs(); // 增量绑定灯箱
}

/* ── 4. 加载更多 ── */
function tkLoadMore() {
  const btn = document.getElementById('loadmore-btn');
  btn.disabled = true;
  requestAnimationFrame(() => {
    tkRenderNext();
    const left = tkAll.length - tkShown;
    if (left <= 0) {
      document.getElementById('talk-loadmore').style.display = 'none';
    } else {
      btn.textContent = `加载更多（还有 ${left} 条）`;
      btn.disabled = false;
    }
  });
}

/* ── 5. 处理 HTML：多图包网格 ── */
function tkProcessHtml(html) {
  const wrap = document.createElement('div');
  wrap.innerHTML = html;

  // 找顶层连续 img 节点（相邻 img 或仅含空白的文本节点之间）
  const nodes = [...wrap.childNodes];
  const imgRuns = []; // [[img, img, ...], ...]
  let run = [];

  nodes.forEach(n => {
    if (n.nodeType === 1 && n.tagName === 'IMG') {
      run.push(n);
    } else {
      // 纯空白文本跳过
      if (n.nodeType === 3 && !n.textContent.trim()) return;
      if (run.length >= 2) imgRuns.push(run);
      run = [];
    }
  });
  if (run.length >= 2) imgRuns.push(run);

  // 把连续多图包裹进网格
  imgRuns.forEach(imgs => {
    const grid = document.createElement('div');
    grid.className = 'talk-imgs';
    imgs[0].before(grid);
    imgs.forEach(img => grid.appendChild(img));
  });

  return wrap.innerHTML;
}

/* ── 6. 灯箱 ── */
function tkBindImgs() {
  document.querySelectorAll('.talk-content img:not([data-tk-lb])').forEach(img => {
    img.setAttribute('data-tk-lb', '1');
    img.addEventListener('click', () => tkOpenLb(img.src));
  });
}

function tkOpenLb(src) {
  document.getElementById('tk-lb-img').src = src;
  document.getElementById('tk-lightbox').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function tkCloseLb(e) {
  if (e && e.target === document.getElementById('tk-lb-img')) return;
  document.getElementById('tk-lightbox').classList.remove('open');
  document.getElementById('tk-lb-img').src = '';
  document.body.style.overflow = '';
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') tkCloseLb(); });

/* ── 7. 时间格式化 ── */
function tkFmtTime(ts) {
  const d = new Date(ts), p = n => String(n).padStart(2, '0');
  return `${d.getFullYear()}-${p(d.getMonth()+1)}-${p(d.getDate())} ${p(d.getHours())}:${p(d.getMinutes())}`;
}

tkInit();
</script>


